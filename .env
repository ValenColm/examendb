PRODUCT_DELETE_ENDPOINT=/api/products/:id
SUPPLIERS_ANALYSIS_ENDPOINT=/api/consultas_avanzadas/suppliers
CUSTOMER_HISTORY_ENDPOINT=/api/consultas_avanzadas/customer/:id/history
TOP_PRODUCTS_ENDPOINT=/api/consultas_avanzadas/top-products?category=
